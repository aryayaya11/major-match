# ══════════════════════════════════════════════════════════════
# MajorMatch Backend — Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control!
# ══════════════════════════════════════════════════════════════

# Flask secret key (REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=your-secret-key-here

# Database connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Admin API key for protected endpoints (/api/stats, /api/export-research)
ADMIN_API_KEY=your-admin-api-key-here

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://majormatch-binbmg5n4-aryayaya11s-projects.vercel.app

# Flask environment (development or production)
FLASK_ENV=production

# Redis URL (optional — used for caching and rate limiting)
# REDIS_URL=redis://localhost:6379/0

# Port (Railway sets this automatically)
# PORT=5000
